# JokerOS Jester Writing Support for Nook Typewriter
# In jest we configure, in laughter we build...

menuconfig JOKEROS
	tristate "JokerOS Jester Writing Support"
	default m
	help
	  This option enables the JokerOS jester-themed kernel subsystem
	  for the Nook Typewriter project. It provides whimsical /proc
	  interfaces including an ASCII jester, writing statistics tracking,
	  and inspirational quotes for writers.

	  Say Y to build into the kernel
	  Say M to build as a loadable module (jokeros.ko)
	  Say N to disable

if JOKEROS

config JOKEROS_JESTER
	bool "ASCII Jester Display"
	default y
	help
	  Enable the ASCII jester that displays mood-based art in
	  /proc/jokeros/jester. The jester's mood changes based on
	  system state and writing activity.

config JOKEROS_TYPEWRITER
	bool "Typewriter Statistics Tracking"
	default y
	help
	  Enable writing statistics tracking including keystrokes,
	  words written, and writing achievements. Statistics are
	  available at /proc/jokeros/typewriter/

config JOKEROS_WISDOM
	bool "Writing Wisdom Quotes"
	default y
	help
	  Enable inspirational writing quotes that rotate randomly.
	  Quotes are available at /proc/jokeros/wisdom

config JOKEROS_DEBUG
	bool "JokerOS Debug Messages"
	default n
	help
	  Enable debug messages for JokerOS subsystem development.
	  This will add verbose kernel log messages.

endif # JOKEROS